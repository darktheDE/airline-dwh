      </DTS:ObjectData>
    </DTS:Executable>
    <!-- 2. SQL - Load Fact from Staging -->
    <DTS:Executable
      DTS:refId="Package\SQL - Load Fact Turnaround Efficiency"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{D2E3F4A5-B6C7-8901-C2D3-E4F5A6B7C8D9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL - Load Fact Turnaround Efficiency">
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E672A47B-07CC-41F2-9F79-E987A337530C}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE dbo.Fact_Turnaround_Efficiency;&#xA;&#xA;INSERT INTO dbo.Fact_Turnaround_Efficiency (&#xA;    ArrivalDateKey, DepartureDateKey, ArrivalTimeKey, DepartureTimeKey, &#xA;    AirportKey, AircraftKey, AirlineKey, &#xA;    BKInboundFlightID, BKOutboundFlightID, &#xA;    Actual_Arrival_Time, Actual_Departure_Time, &#xA;    Actual_Turnaround_Mins, Turnaround_Variance_Mins, Is_Bottleneck&#xA;)&#xA;SELECT &#xA;    dArr.DateKey, dDep.DateKey, &#xA;    (DATEPART(HOUR, stg.Inbound_Arrival_Time) * 100 + DATEPART(MINUTE, stg.Inbound_Arrival_Time)) AS ArrTimeK,&#xA;    (DATEPART(HOUR, stg.Outbound_Departure_Time) * 100 + DATEPART(MINUTE, stg.Outbound_Departure_Time)) AS DepTimeK,&#xA;    ISNULL(ap.AirportKey, -1), ISNULL(ac.AircraftKey, -1), ISNULL(al.AirlineKey, -1),&#xA;    stg.Inbound_Flight_BK, stg.Outbound_Flight_BK,&#xA;    stg.Inbound_Arrival_Time, stg.Outbound_Departure_Time,&#xA;    DATEDIFF(MINUTE, stg.Inbound_Arrival_Time, stg.Outbound_Departure_Time),&#xA;    DATEDIFF(MINUTE, stg.Inbound_Arrival_Time, stg.Outbound_Departure_Time) - 45,&#xA;    CASE WHEN (DATEDIFF(MINUTE, stg.Inbound_Arrival_Time, stg.Outbound_Departure_Time) - 45) &gt; 30 THEN 1 ELSE 0 END&#xA;FROM Airline_Staging.dbo.stg_Turnaround stg&#xA;JOIN Dim_Date dArr ON CAST(stg.Inbound_Arrival_Time AS DATE) = dArr.FullDateAlternateKey&#xA;JOIN Dim_Date dDep ON CAST(stg.Outbound_Departure_Time AS DATE) = dDep.FullDateAlternateKey&#xA;LEFT JOIN Dim_Airport ap ON stg.Turnaround_Airport = ap.BKAirportCode&#xA;LEFT JOIN Dim_Aircraft ac ON stg.Tail_Number = ac.BKTailNumber AND ac.Is_Active = 1&#xA;LEFT JOIN Dim_Airline al ON stg.Airline_Code = al.BKAirlineCode" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
