  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\Populate Dim_Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{8D5281AC-7B2D-4E0A-BBBB-D096D3363DE9}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Populate Dim_Date"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E672A47B-07CC-41F2-9F79-E987A337530C}"
          SQLTask:SqlStatementSource="-- Bước 1: Xoa du lieu cu&#xA;DELETE FROM dbo.Dim_Date WHERE DateKey &lt;&gt; -1&#xA;&#xA;-- Bước 2: Khai bao bien&#xA;DECLARE @StartDate DATE = '2015-01-01'&#xA;DECLARE @EndDate DATE = '2015-12-31'&#xA;DECLARE @CurrentDate DATE = @StartDate&#xA;&#xA;-- Bước 3: Vong lap sinh du lieu&#xA;WHILE @CurrentDate &lt;= @EndDate&#xA;BEGIN&#xA;    INSERT INTO dbo.Dim_Date (&#xA;        DateKey, FullDateAlternateKey, DayNumberOfWeek, DayNameOfWeek, &#xA;        DayOfMonth, MonthNumber, MonthName, CalendarQuarter, CalendarYear, &#xA;        IsWeekend, InsertAuditKey&#xA;    )&#xA;    SELECT &#xA;        CAST(CONVERT(VARCHAR(8), @CurrentDate, 112) AS INT),&#xA;        @CurrentDate,&#xA;        DATEPART(WEEKDAY, @CurrentDate),&#xA;        DATENAME(WEEKDAY, @CurrentDate),&#xA;        DATEPART(DAY, @CurrentDate),&#xA;        DATEPART(MONTH, @CurrentDate),&#xA;        DATENAME(MONTH, @CurrentDate),&#xA;        DATEPART(QUARTER, @CurrentDate),&#xA;        DATEPART(YEAR, @CurrentDate),&#xA;        CASE WHEN DATEPART(WEEKDAY, @CurrentDate) IN (1, 7) THEN 1 ELSE 0 END,&#xA;        -1&#xA;&#xA;    SET @CurrentDate = DATEADD(DAY, 1, @CurrentDate)&#xA;END&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Populate Dim_Time"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{05E0ADD1-162F-4953-BBD4-6459D250FD30}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Populate Dim_Time"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E672A47B-07CC-41F2-9F79-E987A337530C}"
          SQLTask:SqlStatementSource="-- Dọn dẹp dữ liệu cũ (trừ dòng Unknown -1)&#xA;DELETE FROM dbo.Dim_Time WHERE TimeKey &lt;&gt; -1;&#xA;&#xA;DECLARE @Hour INT = 0&#xA;DECLARE @Minute INT = 0&#xA;&#xA;WHILE @Hour &lt; 24&#xA;BEGIN&#xA;    SET @Minute = 0&#xA;    WHILE @Minute &lt; 60&#xA;    BEGIN&#xA;        INSERT INTO dbo.Dim_Time (TimeKey, TimeValue, HourNumber, MinuteNumber, TimePeriod, InsertAuditKey)&#xA;        SELECT &#xA;            (@Hour * 100) + @Minute, -- TimeKey: 1430&#xA;            RIGHT('0' + CAST(@Hour AS VARCHAR(2)), 2) + ':' + RIGHT('0' + CAST(@Minute AS VARCHAR(2)), 2), -- 14:30&#xA;            @Hour,&#xA;            @Minute,&#xA;            CASE &#xA;                WHEN @Hour &gt;= 6 AND @Hour &lt; 12 THEN 'Morning'&#xA;                WHEN @Hour &gt;= 12 AND @Hour &lt; 18 THEN 'Afternoon'&#xA;                WHEN @Hour &gt;= 18 AND @Hour &lt; 24 THEN 'Evening'&#xA;                ELSE 'Night'&#xA;            END,&#xA;            -1&#xA;&#xA;        SET @Minute = @Minute + 1&#xA;    END&#xA;    SET @Hour = @Hour + 1&#xA;END&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
