                          description="Derived Column Expression"
                          name="Expression">(DT_WSTR,30)(#{Package\DFT - Load Fact Flight Transaction\SRC - Flights Incremental.Outputs[OLE DB Source Output].Columns[Airline_Code]} + "-" + (DT_WSTR,10)#{Package\DFT - Load Fact Flight Transaction\SRC - Flights Incremental.Outputs[OLE DB Source Output].Columns[Flight_Number]})</property>
