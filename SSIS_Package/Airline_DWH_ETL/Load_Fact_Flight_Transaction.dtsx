      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E672A47B-07CC-41F2-9F79-E987A337530C}"
          SQLTask:SqlStatementSource="UPDATE ETL_Watermark &#xA;SET Last_Load_Time = (SELECT MAX(Updated_Date) FROM Airline_OLTP.dbo.tb_Flights),&#xA;    Last_Updated = GETDATE()&#xA;WHERE TableName = 'Fact_Flight_Transaction'&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
