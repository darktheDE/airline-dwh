    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Constraint 1]"
      DTS:DTSID="{F1A2B3C4-D5E6-7890-ABCD-67890ABCDEF2}"
      DTS:From="Package\SQL - Extract OLTP to Staging"
      DTS:To="Package\SQL - Load Dim_Aircraft SCD Type 2" />
  </DTS:PrecedenceConstraints>
</DTS:Executable>