  DTS:DTSID="{A1B2C3D4-E5F6-7890-ABCD-1234567890AB}"
  DTS:ExecutableType="Microsoft.Package"
  DTS:LastModifiedProductVersion="17.0.1010.2"
  DTS:LocaleID="1033"
  DTS:ObjectName="Load_Dim_Airport_Airline"
  DTS:PackageType="5"
  DTS:ProtectionLevel="0"
  DTS:VersionBuild="10"
  DTS:VersionGUID="{85628D76-E294-48AB-8E26-7D0A75EE78B8}">
  <DTS:Property
    DTS:Name="PackageFormatVersion">8</DTS:Property>
  <DTS:Variables />
  <DTS:Executables>
    <DTS:Executable
      DTS:refId="Package\SQL - Extract to Staging"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{D1E2F3A4-B5C6-7890-DEFB-4567890ABCDE}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL - Extract to Staging"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{CF4880A4-97D0-4B56-A259-F73552DB41EC}"
          SQLTask:SqlStatementSource="-- 1. EXTRACT AIRPORTS&#xA;INSERT INTO Airline_Staging.dbo.stg_Airports (&#xA;    IATA_Code, Airport_Name, City, State, Country, Latitude, Longitude&#xA;)&#xA;SELECT &#xA;    IATA_Code, Airport_Name, City, State, Country, &#xA;    CAST(Latitude AS NVARCHAR(200)), CAST(Longitude AS NVARCHAR(200))&#xA;FROM Airline_OLTP.dbo.tb_Airports;&#xA;&#xA;-- 2. EXTRACT AIRLINES&#xA;INSERT INTO Airline_Staging.dbo.stg_Airlines (IATA_Code, Airline_Name)&#xA;SELECT IATA_Code, Airline_Name FROM Airline_OLTP.dbo.tb_Airlines;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <!-- 3. Load Dim_Airport (SCD Type 1 via MERGE) -->
    <DTS:Executable
      DTS:refId="Package\SQL - Load Dim_Airport"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{98765432-1B2C-3D4E-5F6G-7890ABCDEF01}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL - Load Dim_Airport"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E672A47B-07CC-41F2-9F79-E987A337530C}"
          SQLTask:SqlStatementSource="MERGE INTO dbo.Dim_Airport AS target&#xA;USING (&#xA;    SELECT &#xA;        IATA_Code, Airport_Name, City, State, &#xA;        TRY_CAST(Latitude AS DECIMAL(8,4)) as Latitude, &#xA;        TRY_CAST(Longitude AS DECIMAL(9,4)) as Longitude&#xA;    FROM Airline_Staging.dbo.stg_Airports&#xA;) AS src&#xA;ON (target.BKAirportCode = src.IATA_Code)&#xA;WHEN MATCHED AND (&#xA;    target.AirportName &lt;&gt; src.Airport_Name OR &#xA;    target.City &lt;&gt; src.City OR &#xA;    target.State &lt;&gt; src.State OR &#xA;    ABS(ISNULL(target.Latitude,0) - ISNULL(src.Latitude,0)) &gt; 0.0001 OR &#xA;    ABS(ISNULL(target.Longitude,0) - ISNULL(src.Longitude,0)) &gt; 0.0001&#xA;) THEN &#xA;    UPDATE SET &#xA;        target.AirportName = src.Airport_Name,&#xA;        target.City = src.City,&#xA;        target.State = src.State,&#xA;        target.Latitude = src.Latitude,&#xA;        target.Longitude = src.Longitude,&#xA;        target.UpdateAuditKey = -2&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (BKAirportCode, AirportName, City, State, Latitude, Longitude, InsertAuditKey, UpdateAuditKey)&#xA;    VALUES (src.IATA_Code, src.Airport_Name, src.City, src.State, src.Latitude, src.Longitude, -2, -1);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Truncate Staging"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{C1D2E3F4-A5B6-7890-CDEF-34567890ABCD}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Truncate Staging"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{CF4880A4-97D0-4B56-A259-F73552DB41EC}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE dbo.stg_Airports;&#xA;TRUNCATE TABLE dbo.stg_Airlines;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <!-- 4. Load Dim_Airline (SCD Type 1 via MERGE) -->
    <DTS:Executable
      DTS:refId="Package\SQL - Load Dim_Airline"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:DTSID="{98765432-1B2C-3D4E-5F6G-7890ABCDEF02}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="SQL - Load Dim_Airline"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{E672A47B-07CC-41F2-9F79-E987A337530C}"
          SQLTask:SqlStatementSource="MERGE INTO dbo.Dim_Airline AS target&#xA;USING (&#xA;    SELECT IATA_Code, Airline_Name FROM Airline_Staging.dbo.stg_Airlines&#xA;) AS src&#xA;ON (target.BKAirlineCode = src.IATA_Code)&#xA;WHEN MATCHED AND (target.AirlineName &lt;&gt; src.Airline_Name) THEN &#xA;    UPDATE SET target.AirlineName = src.Airline_Name, target.UpdateAuditKey = -2&#xA;WHEN NOT MATCHED THEN&#xA;    INSERT (BKAirlineCode, AirlineName, InsertAuditKey, UpdateAuditKey)&#xA;    VALUES (src.IATA_Code, src.Airline_Name, -2, -1);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
  <DTS:PrecedenceConstraints>
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Constraint]"
