      DTS:From="Package\SQL - Extract to Staging"
      DTS:LogicalAnd="True"
      DTS:ObjectName="Constraint 1"
      DTS:To="Package\SQL - Load Dim_Airport" />
    <DTS:PrecedenceConstraint
      DTS:refId="Package.PrecedenceConstraints[Constraint 2]"
      DTS:CreationName=""
      DTS:DTSID="{03456789-0ABC-DEF1-2345-67890ABCDEF2}"
      DTS:From="Package\SQL - Load Dim_Airport"
      DTS:LogicalAnd="True"
      DTS:ObjectName="Constraint 2"
      DTS:To="Package\SQL - Load Dim_Airline" />
  </DTS:PrecedenceConstraints>
